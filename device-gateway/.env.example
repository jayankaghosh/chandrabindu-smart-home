# Port + host the gateway's local HTTP API listens on. Keep it on localhost —
# only the Next app (on the same host) should reach it.
GATEWAY_PORT=4000
GATEWAY_HOST=127.0.0.1

# Optional shared secret. If set, the Next app must send it as `x-gateway-secret`
# and it must match GATEWAY_SECRET in the app's environment. Safe to leave blank
# when the gateway is bound to localhost.
GATEWAY_SECRET=
