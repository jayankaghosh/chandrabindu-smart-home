# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Where the Chandrabindu Next.js app is reachable on the LAN (no trailing slash).
# Same address the mobile wrapper used.
BASE_URL=http://192.168.68.68

# Shared device-pairing secret. MUST match PAIRING_SECRET in the Next app's
# environment. Only a client presenting this secret can exchange a pairing code
# for a token.
PAIRING_SECRET=choose-a-long-random-string

# Comma-separated Telegram numeric user IDs allowed to use the bot. REQUIRED —
# the bot refuses everyone if this is empty. Find your ID via @userinfobot.
ALLOWED_TELEGRAM_IDS=11111111,22222222
